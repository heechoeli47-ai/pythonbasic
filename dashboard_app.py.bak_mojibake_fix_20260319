    # =========================
    def _calc_account_totals_from_trade_map(self):

        total_buy = 0
        total_eval = 0
        total_realized = 0

        for code, t in self.trade_map.items():

            qty = int(getattr(t, "pos_qty", 0))
            avg = float(getattr(t, "avg_price", 0))
            last_raw = getattr(t, "last", 0)

            try:
                last = float(last_raw)
            except:
                last = 0

            # 보유 종목�?계산
            if qty > 0 and last > 0:
                buy_value = qty * avg
                eval_value = qty * last

                total_buy += buy_value
                total_eval += eval_value

            # 실현?먯씡
            total_realized += int(getattr(t, "realized_pnl_today", 0))

        unrealized = total_eval - total_buy
        total_pnl = total_realized + unrealized

        if total_buy > 0:
            total_pct = (total_pnl / total_buy) * 100
        else:
            total_pct = 0

        return (
            int(total_buy),
            int(total_eval),
            int(total_realized),
            int(unrealized),
            int(total_pnl),
            float(total_pct)
        )
