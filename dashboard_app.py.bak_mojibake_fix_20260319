    def _check_exit_strategy(self, code: str, t: TradeItem):

        if t.pos_qty <= 0:
            return

        if getattr(t, "pending_sell", False):
            return

        series_ts = []
        if getattr(self, "use_closed_bar_for_signals", True):
            series, series_ts = self._series_3m_confirmed(t)
        else:
            series, series_ts = self._series_3m(t)
        if not series or len(series) < 20:
            return

        close = float(series[-1])
        if close < t.avg_price * 0.98:
            self.log(f"[MAX LOSS] {code} -> EXIT")
            self._sell_market(code, t.pos_qty, reason="MAX_LOSS")
            return

        # 吏꾩엯 吏곹썑 怨쇰?泥?궛 諛⑹?: 鍮꾩옱?쒖꽦 泥?궛? 理쒖냼 蹂댁쑀 ?쒓컙/遊됱닔 異⑹” ???ㅽ뻾
        entry_ts = float(getattr(t, "entry_ts", 0.0) or 0.0)
        if entry_ts > 0:
            hold_sec = int(getattr(self, "min_hold_sec_after_entry", 90))
            if time.time() - entry_ts < hold_sec:
                return

        entry_bar_ts = int(getattr(t, "entry_bar_ts", 0) or 0)
        if entry_bar_ts > 0 and series_ts:
            bars_since_entry = sum(1 for ts in series_ts if ts > entry_bar_ts)
            if bars_since_entry < int(getattr(self, "min_hold_bars_after_entry", 2)):
                return

        # ?뵶 1截뤴깵 理쒓렐 3遊?????댄깉 ?먯젅 (EMA60 ?꾨옒???뚮쭔 ?곸슜)

        ema60 = ema_series(series, 60)

        recent_lows = series[-4:-1]
        structure_low = min(recent_lows)

        if ema60 and close < ema60[-1] and close < structure_low:
            self.log(f"[STRUCTURE STOP] {code} -> EXIT ALL")
            self._sell_market(code, t.pos_qty, reason="STRUCTURE_BREAK")
            return
        # =========================
        # ?뵶 2截뤴깵 EMA60 ?먯젅 ??2遊??뺤씤
        # =========================
        ema60 = ema_series(series, 60)
        if ema60 and len(ema60) >= 2:

            prev_close = series[-2]

            if close < ema60[-1] and prev_close < ema60[-2]:
                self.log(f"[EMA60 BREAK] {code} -> EXIT ALL")
                self._sell_market(code, t.pos_qty, reason="EMA60_BREAK")
                return

        # =========================
        # ?윟 3截뤴깵 ?몃젅?쇰쭅 ?ㅽ깙
        # =========================
        if t.highest_price < close:
            t.highest_price = close
        # =========================
        # 理쒕? ?먯떎 ?쒗븳
        # =========================
        if close < t.avg_price * 1.01:
            return
        if t.highest_price > 0:
            trailing_price = t.highest_price * (1 - self.trailing_stop_pct)
            if close < trailing_price:
                self.log(f"[TRAILING STOP] {code} -> EXIT ALL")
                self._sell_market(code, t.pos_qty, reason="TRAILING_STOP")
                return

        # =========================
        # ?윞 4截뤴깵 EMA5 / EMA10 ?곕뱶?щ줈???듭젅
        # =========================
        ema5 = ema_series(series, 5)
        ema10 = ema_series(series, 10)

        if ema5 and ema10 and len(ema5) >= 2 and len(ema10) >= 2:
            prev_cross = ema5[-2] >= ema10[-2]
            now_cross = ema5[-1] < ema10[-1]

            if prev_cross and now_cross and close > t.avg_price:
                self.log(f"[EMA DEAD CROSS EXIT] {code} -> EXIT ALL")
                self._sell_market(code, t.pos_qty, reason="EMA_DEAD_CROSS")
                return
    # -------------------------
    # EOD Exit: 15:15 ?댄썑 ?꾨웾 泥?궛
    # -------------------------
    def _check_eod_profit_exit_or_hold(self, code: str, t: TradeItem):

        if t.pos_qty <= 0:
            return

        now = datetime.datetime.now()
        hhmm = now.hour * 100 + now.minute

        if hhmm < 1515:
            return

        today = datetime.date.today().isoformat()

        if t.last_eod_date == today:
            return

        t.last_eod_date = today

        self.log(f"[EOD] 15:15 이후 전량 청산 -> SELL ALL {code}")
        self._sell_market(code, t.pos_qty, reason="EOD full exit")

    # -------------------------
    # Orders (with optional simulation)
    # -------------------------
    def _buy_market(self, code: str, qty: int, reason: str = ""):
        self.log(f"[BUY] {code} qty={qty} arm_live={self.arm_live} reason={reason}")
        t = self.trade_map.get(code)

        # ??기본 방어
        if not t or qty <= 0:
            return

        # ??BUY 중복 방�?
        if t.pending_buy:
            self.log(f"[BUY-SKIP] {code} pending_buy=True (skip) reason={reason}")
            return

        # ??HTS ?곌껐 泥댄겕 (?ㅼ＜臾?紐⑥쓽 紐⑤몢 ?숈씪?섍쾶 濡쒓렇 ?④린怨?醫낅즺)
        if self.ocx.GetConnectState() != 1:
            self.log("[ORDER BLOCK] HTS not connected (GetConnectState!=1)")
            return

        # ???�제부??매수 주문 진행 �??�시
        t.pending_buy = True

        # ?듦퀎
        if self.arm_live:
            self.daily_sum.buy_attempts_live += 1
        else:
            self.daily_sum.buy_attempts_sim += 1
        self.daily_sum._bump(code, "BUY_ATTEMPT", 1)

        # -------------------------
        # 紐⑥쓽: 즉시 체결 ?쒕?
        # -------------------------
        if not self.arm_live:
            try:
                if self.SIM_FILL_WHEN_ARM_OFF and t.last > 0:
                    fill_px = t.last
                    prev_qty = t.pos_qty
                    new_qty = prev_qty + qty

                    if new_qty > 0:
                        new_avg = ((t.avg_price * prev_qty) + (fill_px * qty)) / new_qty if prev_qty > 0 else float(
                            fill_px)
                    else:
                        new_avg = 0.0

                    t.pos_qty = new_qty
                    t.avg_price = new_avg
                    if prev_qty == 0 and new_qty > 0:
                        t.entry_ts = time.time()
                        t.entry_bar_ts = int(getattr(t, "cur_3m_bucket", 0) or 0)
                        t.highest_price = float(fill_px)
                    self.today_spent += fill_px * qty
                    t.used_budget += fill_px * qty
                    t.stage = 1 if t.stage == 0 else min(2, t.stage + 1)
                    t.signal = "HOLD"

                    self._apply_config()
                    self._update_trade_row(code, pos_qty=t.pos_qty, avg_price=t.avg_price, stage=t.stage,
                                           signal=t.signal)
                    self.log(
                        f"  -> SIM FILL BUY: pos_qty={t.pos_qty} avg_price={t.avg_price:.2f} today_spent={self.today_spent:,}")
                else:
                    self.log("  -> ARM LIVE OFF: (mock order only)")
            finally:
                # ??모의???�기??주문 ?�이??종료 ??pending ?�제
                t.pending_buy = False
            return

        # -------------------------
        # ?�전 주문
        # -------------------------
        acc = self.cmb_account.currentText().strip()
        ret = self.ocx.dynamicCall(
            "SendOrder(QString, QString, QString, int, QString, int, int, QString, QString)",
            ["BUY", self.screen_order, acc, 1, code, qty, 0, "03", ""]
        )
        self.log(f"  -> SendOrder ret={ret}")

        # ??SendOrder ?ㅽ뙣 ??pending ?댁젣
        if ret != 0:
            t.pending_buy = False
            self.log(f"[BUY-FAIL] {code} ret={ret} -> pending_buy reset")

    def _sell_market(self, code: str, qty: int, reason: str = ""):
        self.log(f"[SELL] {code} qty={qty} arm_live={self.arm_live} reason={reason}")
        t = self.trade_map.get(code)

        # ??기본 방어
        if not t or qty <= 0:
            return

        # ??SELL 중복 방�?
        if t.pending_sell:
            self.log(f"[SELL-SKIP] {code} pending_sell=True (skip) reason={reason}")
            return

        # ??HTS ?곌껐 泥댄겕
        if self.ocx.GetConnectState() != 1:
            self.log("[ORDER BLOCK] HTS not connected (GetConnectState!=1)")
            return

        # ???�제부??매도 주문 진행 �??�시
        t.pending_sell = True

        # ?듦퀎
        if self.arm_live:
            self.daily_sum.sell_attempts_live += 1
        else:
            self.daily_sum.sell_attempts_sim += 1
        self.daily_sum._bump(code, "SELL_ATTEMPT", 1)

        # -------------------------
        # 紐⑥쓽: 즉시 체결 ?쒕?
        # -------------------------
        if not self.arm_live:
            try:
                if self.SIM_FILL_WHEN_ARM_OFF:
                    # ??SIM 留ㅻ룄 실현?먯씡 ?꾩쟻
                    if t.pos_qty > 0 and t.avg_price > 0 and t.last > 0:
                        sell_qty = min(qty, t.pos_qty)
                        t.realized_pnl_today += int((t.last - t.avg_price) * sell_qty)

                    t.pos_qty = max(0, t.pos_qty - qty)
                    if t.pos_qty == 0:
                        t.avg_price = 0.0
                        t.stage = 0
                        t.signal = "WAIT"
                        t.stop1_done = False
                    else:
                        t.signal = "HOLD"

                    self._update_trade_row(code, pos_qty=t.pos_qty, avg_price=t.avg_price, stage=t.stage,
                                            signal=t.signal)
                    self.log(f"  -> SIM FILL SELL: pos_qty={t.pos_qty} avg_price={t.avg_price:.2f}")
                else:
                    self.log("  -> ARM LIVE OFF: (mock order only)")
            finally:
                # ??모의???�기??주문 ?�이??종료 ??pending ?�제
                t.pending_sell = False
            return

        # -------------------------
        # ?�전 주문
        # -------------------------
        acc = self.cmb_account.currentText().strip()
        ret = self.ocx.dynamicCall(
            "SendOrder(QString, QString, QString, int, QString, int, int, QString, QString)",
            ["SELL", self.screen_order, acc, 2, code, qty, 0, "03", ""]
        )
        self.log(f"  -> SendOrder ret={ret}")

        # ??SendOrder ?ㅽ뙣 ??pending ?댁젣
        if ret != 0:
            t.pending_sell = False
            self.log(f"[SELL-FAIL] {code} ret={ret} -> pending_sell reset")

