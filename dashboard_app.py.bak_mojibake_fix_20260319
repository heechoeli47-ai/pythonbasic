    def _calc_eval_pnl(self, t):
        """
        ?ㅼ떆媛?'평가?먯씡(??' / '수익률%)' 怨꾩궛.
        - ?섏닔猷??멸툑 誘몃컲??
        """
        if not t or t.pos_qty <= 0:
            return 0, 0.0
        if t.last <= 0 or t.avg_price <= 0:
            return 0, 0.0

        eval_pnl = int((t.last - t.avg_price) * t.pos_qty)
        pnl_pct = ((t.last / t.avg_price) - 1.0) * 100.0
        return eval_pnl, pnl_pct

