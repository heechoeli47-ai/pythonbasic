    def _on_receive_chejan_data(self, gubun, itemCnt, fidList):

        gubun = str(gubun).strip()
        code = clean_code(self._get_chejan(CHEJAN_FID["code"]))
        if not code:
            return

        # trade_map ?먮룞 ?앹꽦
        if code not in self.trade_map:
            self.trade_map[code] = TradeItem(code=code)
            self.log(f"[CHEJAN] auto-create trade_map item for {code}")

        t = self.trade_map[code]

        # =====================================================
        # 1截뤴깵 Chejan-0 : 체결媛 ????꾩슜 (?뚭퀎 泥섎━ X)
        # =====================================================
        if gubun == "0":

            status = self._get_chejan(CHEJAN_FID["order_status"]).strip()
            filled_qty = to_int(self._get_chejan(CHEJAN_FID["filled_qty"]))
            filled_price = abs(to_int(self._get_chejan(CHEJAN_FID["filled_price"])))

            if status != "체결" or filled_qty <= 0:
                return

            # 체결媛 ???(Chejan-1?먯꽌 ?ъ슜)
            t.last_fill_price = filled_price
            t.last_fill_qty = filled_qty

            self.log(f"[CHEJAN-0] {code} price={filled_price} qty={filled_qty}")
            return

        # =====================================================
        # 2截뤴깵 Chejan-1 : ?뚭퀎 理쒖쥌 泥섎━ (?ш린?쒕쭔 怨꾩궛)
        # =====================================================
        elif gubun == "1":

            new_qty = to_int(self._get_chejan(CHEJAN_FID["pos_qty"]))
            new_avg = to_float(self._get_chejan(CHEJAN_FID["avg_price"]))

            old_qty = t.pos_qty
            old_avg = t.avg_price

            # -------------------------
            # ?윟 留ㅼ닔 체결 媛먯?
            # -------------------------
            if new_qty > old_qty:
                t.pending_buy = False

                filled_qty = new_qty - old_qty
                total_cost = int(new_avg * filled_qty)

                self.today_total_spent += total_cost
                self.today_spent += total_cost
                t.used_budget += total_cost
                if old_qty == 0:
                    t.entry_ts = time.time()
                    t.entry_bar_ts = int(getattr(t, "cur_3m_bucket", 0) or 0)
                    t.highest_price = float(new_avg)

                self.log(f"[SYNC BUY] {code} qty={filled_qty} avg={new_avg:.2f}")

            # -------------------------
            # ?뵶 留ㅻ룄 체결 媛먯?
            # -------------------------
            elif new_qty < old_qty:
                t.pending_sell = False

                sold_qty = old_qty - new_qty

                filled_price = (
                    t.last_fill_price
                    if hasattr(t, "last_fill_price") and t.last_fill_price > 0
                    else t.last
                )

                realized = int((filled_price - old_avg) * sold_qty)

                self.today_total_realized += realized
                t.realized_pnl_today += realized

                self.log(
                    f"[REALIZED] {code} "
                    f"sell={filled_price} avg={old_avg:.2f} "
                    f"qty={sold_qty} realized={realized:,}"
                )
                # =========================
                # ?�진??쿨다??기록
                # =========================
                t.last_sell_time = time.time()

                if new_qty == 0:
                    self._reset_position_state(t)

            # -------------------------
            # 理쒖쥌 ?숆린??
            # -------------------------
            t.pos_qty = new_qty
            t.avg_price = new_avg

            self._update_trade_row(
                code,
                pos_qty=new_qty,
                avg_price=new_avg,
                stage=t.stage,
                signal=t.signal
            )
            #怨꾩쥖 ?붿빟 媛깆떊 (?듭떖)
            self._update_account_summary_program()
            self.log(
                f"[CHEJAN-1] {code} "
                f"pos_qty={new_qty} avg_price={new_avg:.2f} "
                f"today_total_spent={self.today_total_spent:,} "
                f"today_total_realized={self.today_total_realized:,}"
            )
