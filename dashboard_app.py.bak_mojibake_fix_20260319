    def _check_buy_rsi_only(self, t) -> bool:
        """
        RSI ?⑤룆 留ㅼ닔 ?먮떒 (?뺤젙 3遺꾨큺 湲곗?)
        """
        BUY_RSI = self.rsi_buy_level


        # ?대? ?ъ????덉쑝硫?留ㅼ닔 湲덉?
        if t.pos_qty > 0:
            return False

        rsis = getattr(t, "rsi_hist_3m", [])
        if len(rsis) < 3:
            return False

        rsi_2ago = rsis[-3]
        rsi_1ago = rsis[-2]
        rsi_now = rsis[-1]

        # 조건 1: 과매??구간
        if rsi_now > BUY_RSI:
            return False

        # 조건 2: RSI 반등 구조
        if not (rsi_1ago <= rsi_2ago and rsi_now >= rsi_1ago):
            return False

        return True

    def _check_entry_condition_3m(self, code: str, t: TradeItem):
        # =========================
        # [AUTO TRADE GUARD][異붽?] ?ъ쭊??荑⑤떎??15:15 ?댄썑 ?좉퇋 留ㅼ닔 湲덉?
        # =========================
        self._check_market_strength()
        if self.market_up < self.market_down:
            return
        if hasattr(t, "last_sell_time"):
            if time.time() - t.last_sell_time < 300:
                return
        if datetime.datetime.now().time() >= datetime.time(15, 15):
            return

        if self.is_warmup:
            return
        if not self.auto_trade_enabled:
            return
        if not self.warmup_ready.get(code, False):
            return

        # series 준�?
        series_ts = []
        if getattr(self, "use_closed_bar_for_signals", True):
            series, series_ts = self._series_3m_confirmed(t)
        else:
            series, series_ts = self._series_3m(t)
        if len(series) < self.macd_slow + self.macd_signal + 2:
            return
        if t.last <= 0:
            return
        if not series_ts:
            return

        last_closed_bucket = int(series_ts[-1])
        if getattr(t, "last_entry_bucket", -1) == last_closed_bucket:
            return

        mres = macd_series(series, self.macd_fast, self.macd_slow, self.macd_signal)
        if mres is None:
            return
        m, s, h = mres

        r = rsi_series(series, self.rsi_period)
        if not r or r[-1] is None:
            return
        rsi_last = float(r[-1])
        # ?????쒖떆??吏??媛????(3以??⑥튂)
        t.macd_3m = float(m[-1] - s[-1])  # ?먮뒗 m[-1] 媛믩쭔 ?⑤룄 ??
        t.rsi_3m = float(rsi_last)
        self._update_trade_row(code, macd_3m=t.macd_3m, rsi_3m=t.rsi_3m)

        cur_bucket = t.cur_3m_bucket if t.cur_3m_bucket else self._bucket_start(
            int(datetime.datetime.now().timestamp()), 180)

        per_stock = self._per_stock_budget()
        if per_stock <= 0:
            return

        # =========================
        # 공통 준�?
        # =========================
        close_now = series[-1]
        prev_close = series[-2]
        prev_rsi = r[-2]
        # =========================
        # ?몃젰 거래량?꾪꽣
        # =========================
        vols = getattr(t, "vol_hist_3m", [])

        if len(vols) >= 5:
            avg_vol = sum(vols[-5:]) / 5

            if vols[-1] < avg_vol * 1.3:
                return

        ema20 = ema_series(series, 20)
        ema60 = ema_series(series, 60)

        ema20_last = ema20[-1] if ema20 else None
        ema60_last = ema60[-1] if ema60 else None
        # =========================
        # 異붿꽭 ?뺣젹 ?뺤씤
        # =========================
        if not (close_now > ema20_last > ema60_last):
            return

        if not ema20 or not ema60:
            return

        ema20_last = ema20[-1]
        ema20_prev = ema20[-2]
        ema60_last = ema60[-1]
        # =========================
        # [異붽?] EMA60 異붿꽭 ?꾪꽣
        # =========================
        if close_now < ema60_last:
            return
        # =========================
        # BUY1
        # =========================
        buy1_triggered = False

        if close_now > ema60_last and ema60[-1] > ema60[-2]:
            # ?섏젙
            if m[-1] > s[-1]:
                if rsi_last <= self.rsi_buy_level:
                    t.rsi_was_below = True

                cross_up = (prev_rsi <= self.rsi_buy_level and rsi_last > self.rsi_buy_level)

                if getattr(t, "rsi_was_below", False) and cross_up:
                    buy1_triggered = True

        if buy1_triggered:
            remaining_budget = per_stock - t.used_budget
            if remaining_budget > 0:
                budget = int(remaining_budget * 0.3)
                qty = budget // max(1, t.last)

                if qty > 0:

                    # =========================
                    # 1?뚯꽦 ?몃━嫄?蹂댄샇
                    # =========================
                    if getattr(t, "entry_triggered", False):
                        return

                    t.last_entry_bucket = last_closed_bucket
                    self._buy_market(code, qty, reason="BUY1_PULLBACK")

                    # ?몃━嫄??쒖꽦??
                    t.entry_triggered = True

                    t.rsi_was_below = False
        # =========================
        # BUY2
        # =========================
        buy2_triggered = False

        ema20_break = (prev_close <= ema20_prev and close_now > ema20_last)
        rsi_break_50 = (prev_rsi <= 50 and rsi_last > 50)
        # MACD ?⑥닚??(0318??
        macd_positive = (m[-1] > s[-1])

        if ema20_break and rsi_break_50 and macd_positive:
            buy2_triggered = True

        if buy2_triggered:
            remaining_budget = per_stock - t.used_budget
            if remaining_budget > 0:
                budget = int(remaining_budget * 0.5)
                qty = budget // max(1, t.last)

                if qty > 0:

                    # =========================
                    #  1?뚯꽦 ?몃━嫄?蹂댄샇
                    # =========================
                    if getattr(t, "entry_triggered", False):
                        return

                    t.last_entry_bucket = last_closed_bucket
                    self._buy_market(code, qty, reason="BUY2_BREAKOUT")

                    #  ?몃━嫄??쒖꽦??
                    t.entry_triggered = True

